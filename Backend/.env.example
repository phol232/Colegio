# NestJS Application
NODE_ENV=development
PORT=3000
APP_NAME=Academic Management API
APP_VERSION=1.0.0

# Database OLTP (via PgBouncer in Docker)
DB_HOST=pgbouncer
DB_PORT=6432
DB_DATABASE=academic_oltp
DB_USERNAME=academic
DB_PASSWORD=your_secure_password_here

# Migraciones TypeORM CLI (conexión directa a PostgreSQL :5432)
# DB_PORT=5432

# Database OLAP
DB_OLAP_HOST=pgbouncer
DB_OLAP_PORT=6432
DB_OLAP_DATABASE=academic_olap
DB_OLAP_USERNAME=academic
DB_OLAP_PASSWORD=your_secure_password_here

# Redis Cache (LRU)
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379
REDIS_CACHE_DB=0

# Redis Queue (noeviction / AOF)
REDIS_QUEUE_HOST=redis-queue
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_DB=0

# Throttle (matches Laravel api.php)
THROTTLE_TTL=60
THROTTLE_AUTH_LIMIT=200
THROTTLE_API_LIMIT=500

# Auth token cache TTL (seconds)
AUTH_TOKEN_CACHE_TTL=60

# CORS
CORS_ORIGIN=*
