{
  "name": "academic-backend",
  "version": "1.0.0",
  "description": "Academic Management API - NestJS layered architecture",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "esbuild", "msgpackr-extract"]
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "start:worker": "node dist/worker.main.js",
    "start:scheduler": "node dist/scheduler.main.js",
    "start:worker:dev": "tsx watch src/worker.main.ts",
    "start:scheduler:dev": "tsx watch src/scheduler.main.ts",
    "create:admin": "tsx src/scripts/create-admin.ts",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:cov": "jest --coverage",
    "migration:run:oltp": "typeorm-ts-node-commonjs migration:run -d src/infrastructure/typeorm/data-source.oltp.ts",
    "migration:run:olap": "typeorm-ts-node-commonjs migration:run -d src/infrastructure/typeorm/data-source.olap.ts",
    "migration:revert:oltp": "typeorm-ts-node-commonjs migration:revert -d src/infrastructure/typeorm/data-source.oltp.ts",
    "migration:revert:olap": "typeorm-ts-node-commonjs migration:revert -d src/infrastructure/typeorm/data-source.olap.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.1",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis-yet": "^2.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.2.2",
    "typeorm": "^0.3.30",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.12",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
