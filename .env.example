# Application
APP_NAME="Academic Management System"
APP_ENV=production
APP_VERSION=1.0.0
APP_URL=https://apicolegio.optrix.cloud
PORT=3000
NODE_ENV=production

# Contraseña del rol "academic" creado en el PostgreSQL compartido citas-db.
# Debe ser segura para URL (por ejemplo, la salida de: openssl rand -hex 24).
# Database OLTP (Transactional) - Via PgBouncer
DB_HOST=pgbouncer
DB_PORT=6432
DB_DATABASE=academic_oltp
DB_USERNAME=academic
DB_PASSWORD=your_secure_password_here

# Database OLAP (Analytical)
DB_OLAP_HOST=pgbouncer
DB_OLAP_PORT=6432
DB_OLAP_DATABASE=academic_olap
DB_OLAP_USERNAME=academic
DB_OLAP_PASSWORD=your_secure_password_here

# Redis Cache (LRU — ephemeral)
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379
REDIS_CACHE_DB=0

# Redis Queue (AOF + noeviction — BullMQ)
REDIS_QUEUE_HOST=redis-queue
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_DB=0

# Throttle (aligned with NestJS + nginx)
THROTTLE_TTL=60
THROTTLE_AUTH_LIMIT=200
THROTTLE_API_LIMIT=500
AUTH_TOKEN_CACHE_TTL=60

# CORS
# Dominio público del frontend desplegado en Vercel.
# Se pueden indicar varios orígenes separados por comas.
CORS_ORIGIN=https://tu-proyecto.vercel.app

# Logging
LOG_LEVEL=info

# Backup
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/var/backups/academic
